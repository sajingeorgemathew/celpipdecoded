# CELPIP Decoded Supabase project
# Copy this file to .env.local and fill in real values.
# Never commit .env.local or real keys.

# Public values, safe for the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server only. Never expose this to the browser or client components.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Base URL of the app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server only. OpenAI transcription and scoring for speaking attempts,
# plus writing evaluation. Never expose these to the browser or client
# components.
OPENAI_API_KEY=your-openai-api-key
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_SCORING_MODEL=gpt-5.4-mini
OPENAI_WRITING_MODEL=gpt-5.4-mini
